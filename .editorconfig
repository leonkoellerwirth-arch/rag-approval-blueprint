# EditorConfig — consistent whitespace across every editor. Copy to a repo root as .editorconfig.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{py,sh}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false   # trailing two spaces are a hard line break in Markdown

[Makefile]
indent_style = tab
