{
  "name": "rag-freigabeakte-assistent",
  "version": "0.1.0",
  "description": "Assistent f\u00fcr die Freigabeakte eines RAG-Systems im regulierten Umfeld \u2014 lokal, ohne Netzzugriff.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "deploy": "./deploy/deploy.sh",
    "verify": "npm run typecheck && npm run lint && npm run build && npm run build:datei",
    "verify:ci": "npm run typecheck && npm run lint && npm test -- --run && npm run build && npm run build:datei",
    "build:datei": "tsc --noEmit && VITE_EINZELDATEI=1 vite build"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.14.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.0.0"
  }
}
